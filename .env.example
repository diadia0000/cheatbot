# LINE Messaging API credentials
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# ngrok auth token (from https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=your_ngrok_authtoken

# Optional: set a fixed public URL if you use reserved domain/custom domain
# If left empty, backend will try to infer from ngrok forwarded headers.
LINE_BACKEND_PUBLIC_URL=
